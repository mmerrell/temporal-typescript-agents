#!/bin/bash
fail() { echo "FAIL: $1"; exit 1; }
pass() { echo "PASS: $1"; }

# Check that at least one weatherAgentWorkflow completed
COMPLETED=$(temporal workflow list \
    --address 127.0.0.1:7233 \
    --query 'WorkflowType="weatherAgentWorkflow" AND ExecutionStatus="Completed"' \
    2>/dev/null | grep -c "Completed" || true)

if [ "$COMPLETED" -lt 1 ]; then
    fail "No completed weatherAgentWorkflow found. Run the worker and starter2.ts, then try again."
fi
pass "At least one weatherAgentWorkflow completed"

# Confirm proxyActivities is used (not direct calls)
FILE="/workspace/workshop/agent/demo2-workflow.ts"
if ! grep -q "proxyActivities" "$FILE"; then
    fail "proxyActivities not found in demo2-workflow.ts"
fi
pass "proxyActivities found in demo2-workflow.ts"

echo "Demo 2 complete."
