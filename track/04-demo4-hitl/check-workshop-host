#!/bin/bash
fail() { echo "FAIL: $1"; exit 1; }
pass() { echo "PASS: $1"; }

# Check that at least one weatherAgentHITLWorkflow completed
COMPLETED=$(temporal workflow list \
    --address 127.0.0.1:7233 \
    --query 'WorkflowType="weatherAgentHITLWorkflow" AND ExecutionStatus="Completed"' \
    2>/dev/null | grep -c "Completed" || true)

if [ "$COMPLETED" -lt 1 ]; then
    fail "No completed weatherAgentHITLWorkflow found. Run the worker and starter4.ts, answer the question, then try again."
fi
pass "At least one weatherAgentHITLWorkflow completed"

# Confirm signal is defined in demo4-hitl.ts
FILE="/workspace/workshop/agent/demo4-hitl.ts"
if ! grep -q "defineSignal" "$FILE"; then
    fail "defineSignal not found in demo4-hitl.ts"
fi
pass "Signal definition found"

if ! grep -q "condition" "$FILE"; then
    fail "condition() not found in demo4-hitl.ts — HITL suspension is missing"
fi
pass "condition() found (durable suspend)"

# Confirm at least one signal was received in any HITL workflow run
SIGNALED=$(temporal workflow list \
    --address 127.0.0.1:7233 \
    --query 'WorkflowType="weatherAgentHITLWorkflow"' \
    2>/dev/null | grep -c "weatherAgentHITLWorkflow" || true)

if [ "$SIGNALED" -lt 1 ]; then
    fail "No HITL workflow runs found at all"
fi
pass "HITL workflow runs found"

echo "Demo 4 complete. Workshop finished."
