#!/bin/bash
fail() { echo "FAIL: $1"; exit 1; }
pass() { echo "PASS: $1"; }

# Verify demo1-raw.ts exists and has no Temporal imports
FILE="/workspace/workshop/agent/demo1-raw.ts"
if [ ! -f "$FILE" ]; then
    fail "demo1-raw.ts not found"
fi
pass "demo1-raw.ts exists"

if grep -q "@temporalio" "$FILE"; then
    fail "demo1-raw.ts should not import from @temporalio — it's the raw loop"
fi
pass "No Temporal imports in demo1-raw.ts (as expected)"

# Check that the Anthropic SDK is imported (confirms it's actually using Claude)
if ! grep -q "@anthropic-ai/sdk" "$FILE"; then
    fail "demo1-raw.ts does not import the Anthropic SDK"
fi
pass "Anthropic SDK import found"

echo "Demo 1 complete."
