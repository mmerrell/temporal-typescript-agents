#!/bin/bash
fail() { echo "FAIL: $1"; exit 1; }
pass() { echo "PASS: $1"; }

# Check that at least one weatherAgentCleanWorkflow completed
COMPLETED=$(temporal workflow list \
    --address 127.0.0.1:7233 \
    --query 'WorkflowType="weatherAgentCleanWorkflow" AND ExecutionStatus="Completed"' \
    2>/dev/null | grep -c "Completed" || true)

if [ "$COMPLETED" -lt 1 ]; then
    fail "No completed weatherAgentCleanWorkflow found. Run the worker and starter3.ts, then try again."
fi
pass "At least one weatherAgentCleanWorkflow completed"

# Confirm toolHandlers map is present (not an if/else chain)
FILE="/workspace/workshop/agent/demo3-clean.ts"
if ! grep -q "toolHandlers" "$FILE"; then
    fail "toolHandlers registry not found in demo3-clean.ts"
fi
pass "toolHandlers registry found"

if grep -q "} else if" "$FILE"; then
    fail "demo3-clean.ts still has an if/else chain — it should use the toolHandlers map"
fi
pass "No if/else chain in demo3-clean.ts"

echo "Demo 3 complete."
