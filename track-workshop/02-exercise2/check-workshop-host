#!/bin/bash
fail() { echo "FAIL: $1"; exit 1; }
pass() { echo "PASS: $1"; }

ACTIVITIES_FILE="/workspace/workshop/exercises/2_tool_activities/exercise/activities.ts"
WORKFLOW_FILE="/workspace/workshop/exercises/2_tool_activities/exercise/workflow.ts"

# Check tool activities are implemented (not stubs)
if grep -q "throw new Error(\"Not implemented\")" "$ACTIVITIES_FILE"; then
    fail "At least one tool activity still throws 'Not implemented' — complete the implementation in activities.ts"
fi
pass "Tool activities implemented"

# Check tool activities are proxied in workflow
if ! grep -q "getWeatherAlerts" "$WORKFLOW_FILE" || grep -q "TODO: Add tool" "$WORKFLOW_FILE"; then
    fail "Tool activities not proxied in workflow.ts — add them to proxyActivities"
fi
pass "Tool activities proxied in workflow"

# Check TODO placeholders are gone from workflow
if grep -q "TODO: call" "$WORKFLOW_FILE"; then
    fail "TODO placeholders still present in workflow.ts — replace them with actual activity calls"
fi
pass "No TODO placeholders remaining in workflow.ts"

# Check no I/O imports in workflow
if grep -qE "^import.*(node-fetch|https-proxy-agent|HttpsProxyAgent|nodeFetch)" "$WORKFLOW_FILE"; then
    fail "workflow.ts imports I/O libraries — these belong in activities.ts only"
fi
pass "No I/O imports in workflow.ts"

# Check at least one weatherAgentWorkflow completed
COMPLETED=$(temporal workflow list \
    --address 127.0.0.1:7233 \
    --query 'WorkflowType="weatherAgentWorkflow" AND ExecutionStatus="Completed"' \
    2>/dev/null | grep -c "Completed" || true)

if [ "$COMPLETED" -lt 1 ]; then
    fail "No completed weatherAgentWorkflow found. Run the worker and starter, then try again."
fi
pass "At least one weatherAgentWorkflow completed"

echo "Exercise 2 complete."
