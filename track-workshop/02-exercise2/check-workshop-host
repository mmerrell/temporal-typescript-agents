#!/bin/bash
fail() { echo "FAIL: $1"; exit 1; }
pass() { echo "PASS: $1"; }

ACTIVITIES_FILE="/workspace/workshop/exercises/2_tool_activities/exercise/activities.ts"
WORKFLOW_FILE="/workspace/workshop/exercises/2_tool_activities/exercise/workflow.ts"

# Check tool activities are implemented
for fn in getWeatherAlerts getCoordinates getDistanceKm; do
    if grep -q "throw new Error(\"Not implemented\")" "$ACTIVITIES_FILE"; then
        fail "At least one tool activity still throws 'Not implemented' — check activities.ts"
    fi
done
pass "Tool activities implemented"

# Check proxyActivities includes tool activities
if ! grep -q "getWeatherAlerts" "$WORKFLOW_FILE"; then
    fail "getWeatherAlerts not wired up in workflow.ts — add it to proxyActivities"
fi
pass "getWeatherAlerts proxied in workflow"

if ! grep -q "getCoordinates" "$WORKFLOW_FILE"; then
    fail "getCoordinates not wired up in workflow.ts"
fi
pass "getCoordinates proxied in workflow"

# Check throw stubs are removed
if grep -q "not wired up yet" "$WORKFLOW_FILE"; then
    fail "Stub errors still present in workflow.ts — replace the throw lines with activity calls"
fi
pass "No stub errors remaining in workflow.ts"

# Check at least one workflow completed
COMPLETED=$(temporal workflow list \
    --address 127.0.0.1:7233 \
    --query 'WorkflowType="weatherAgentWorkflow" AND ExecutionStatus="Completed"' \
    2>/dev/null | grep -c "Completed" || true)

if [ "$COMPLETED" -lt 1 ]; then
    fail "No completed weatherAgentWorkflow found. Run the worker and starter, then try again."
fi
pass "At least one weatherAgentWorkflow completed"

echo "Exercise 2 complete."
