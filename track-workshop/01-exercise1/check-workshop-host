#!/bin/bash
fail() { echo "FAIL: $1"; exit 1; }
pass() { echo "PASS: $1"; }

WORKFLOW_FILE="/workspace/workshop/exercises/1_temporalize/exercise/workflow.ts"

# Check proxyActivities is used
if ! grep -q "proxyActivities" "$WORKFLOW_FILE"; then
    fail "proxyActivities not found in workflow.ts — create activity proxies for callLLM and the tool activities"
fi
pass "proxyActivities found"

# Check workflow function is exported
if ! grep -q "export async function weatherAgentWorkflow" "$WORKFLOW_FILE"; then
    fail "weatherAgentWorkflow not exported from workflow.ts"
fi
pass "weatherAgentWorkflow exported"

# Check no I/O imports in workflow (the key correctness rule)
if grep -qE "^import.*(node-fetch|https-proxy-agent|HttpsProxyAgent|nodeFetch)" "$WORKFLOW_FILE"; then
    fail "workflow.ts imports I/O libraries — these belong in activities.ts only, never in workflow files"
fi
pass "No I/O imports in workflow.ts"

# Check the TODO placeholders are gone
if grep -q "TODO: call" "$WORKFLOW_FILE"; then
    fail "TODO placeholders still present in workflow.ts — replace them with actual activity calls"
fi
pass "No TODO placeholders remaining"

# Check at least one weatherAgentWorkflow completed
COMPLETED=$(temporal workflow list \
    --address 127.0.0.1:7233 \
    --query 'WorkflowType="weatherAgentWorkflow" AND ExecutionStatus="Completed"' \
    2>/dev/null | grep -c "Completed" || true)

if [ "$COMPLETED" -lt 1 ]; then
    fail "No completed weatherAgentWorkflow found. Run the worker and starter, then try again."
fi
pass "At least one weatherAgentWorkflow completed"

echo "Exercise 1 complete."
